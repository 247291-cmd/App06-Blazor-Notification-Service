@page "/notifications"
@rendermode InteractiveServer
@inject App06_Notifications.Services.NotificationService NotificationSvc
@inject App06_Notifications.Services.NotificationConfig Config

<PageTitle>Notifications</PageTitle>

<div class="min-vh-100" style="background: linear-gradient(135deg, #a18cd1 0%, #fbc2eb 100%);">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-7 col-lg-6">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h2 class="text-white fw-bold mb-0">🔔 Notifications</h2>
                        <p class="text-white opacity-75 mb-0 small">@Config.NotificationStyle view · @notifications.Count items</p>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-light btn-sm rounded-pill px-3" @onclick="LoadNotifications">Refresh</button>
                        <a href="/" class="btn btn-outline-light btn-sm rounded-pill px-3">Settings</a>
                    </div>
                </div>

                <div class="card border-0 shadow-lg" style="border-radius:20px; overflow:hidden;">
                    @if (isLoading)
                    {
                        <div class="text-center py-5">
                            <div class="spinner-border" style="color:#a18cd1;" role="status"></div>
                            <p class="mt-3 text-muted">Loading...</p>
                        </div>
                    }
                    else if (Config.NotificationStyle == "Compact")
                    {
                        @foreach (var n in notifications)
                        {
                            <div class="d-flex align-items-center px-4 py-3 border-bottom @(n.IsRead ? "" : "bg-light")">
                                <div class="me-3" style="font-size:1.2rem;">
                                    @(n.IsRead ? "📭" : "📬")
                                </div>
                                <span class="flex-grow-1 @(n.IsRead ? "text-muted" : "fw-semibold")">@n.Message</span>
                                @if (!n.IsRead) { <span class="badge bg-danger rounded-pill">New</span> }
                            </div>
                        }
                    }
                    else
                    {
                        <div class="p-3">
                            @foreach (var n in notifications)
                            {
                                <div class="p-3 mb-2 rounded-3 @(n.IsRead ? "bg-light" : "bg-white border")"
                                     style="@(n.IsRead ? "" : "border-left: 4px solid #a18cd1 !important;")">
                                    <div class="d-flex justify-content-between align-items-start mb-1">
                                        <span class="@(n.IsRead ? "text-muted" : "fw-semibold")">@n.Message</span>
                                        @if (!n.IsRead) { <span class="badge rounded-pill ms-2 flex-shrink-0" style="background:#a18cd1;">New</span> }
                                    </div>
                                    <small class="text-muted">🕐 @n.Timestamp.ToString("MMM dd · hh:mm tt")</small>
                                </div>
                            }
                        </div>
                    }
                </div>

            </div>
        </div>
    </div>
</div>

@code {
    private List<App06_Notifications.Services.NotificationItem> notifications = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync() => await LoadNotifications();

    private async Task LoadNotifications()
    {
        isLoading = true;
        notifications = await NotificationSvc.GetNotificationsAsync();
        isLoading = false;
    }
}
