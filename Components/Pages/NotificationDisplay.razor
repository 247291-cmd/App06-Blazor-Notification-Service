@page "/notifications"
@rendermode InteractiveServer
@inject App06_Notifications.Services.NotificationService NotificationSvc
@inject App06_Notifications.Services.NotificationConfig Config

<PageTitle>Notifications - App 06</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold text-dark mb-0">Notifications</h2>
                    <p class="text-muted mb-0 small">@Config.NotificationStyle view · @notifications.Count items</p>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary btn-sm rounded-pill px-3" @onclick="LoadNotifications">Refresh</button>
                    <a href="/" class="btn btn-outline-secondary btn-sm rounded-pill px-3">Settings</a>
                </div>
            </div>
            <div class="card border-0 shadow" style="border-radius:16px; overflow:hidden;">
                @if (isLoading)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status"></div>
                        <p class="mt-3 text-muted">Loading...</p>
                    </div>
                }
                else if (Config.NotificationStyle == "Compact")
                {
                    @foreach (var n in notifications)
                    {
                        <div class="d-flex align-items-center px-4 py-3 border-bottom @(n.IsRead ? "" : "bg-light")">
                            <span class="me-3" style="font-size:1.2rem;">@(n.IsRead ? "📭" : "📬")</span>
                            <span class="flex-grow-1 text-dark @(n.IsRead ? "text-muted" : "fw-semibold")">@n.Message</span>
                            @if (!n.IsRead) { <span class="badge bg-danger rounded-pill ms-2">New</span> }
                        </div>
                    }
                }
                else
                {
                    <div class="p-3">
                        @foreach (var n in notifications)
                        {
                            <div class="p-3 mb-2 rounded-3 border @(n.IsRead ? "bg-light" : "bg-white")"
                                 style="@(n.IsRead ? "" : "border-left:4px solid #0891b2 !important;")">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="text-dark @(n.IsRead ? "text-muted" : "fw-semibold")">@n.Message</span>
                                    @if (!n.IsRead) { <span class="badge rounded-pill ms-2 flex-shrink-0 text-white" style="background:#0891b2;">New</span> }
                                </div>
                                <small class="text-muted">@n.Timestamp.ToString("MMM dd, yyyy · hh:mm tt")</small>
                            </div>
                        }
                    </div>
                }
                <div class="px-4 py-2 bg-light d-flex justify-content-between border-top">
                    <small class="text-muted">@notifications.Count notification(s)</small>
                    <small class="text-muted">@Config.NotificationStyle view</small>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<App06_Notifications.Services.NotificationItem> notifications = new();
    private bool isLoading = true;
    protected override async Task OnInitializedAsync() => await LoadNotifications();
    private async Task LoadNotifications()
    {
        isLoading = true;
        notifications = await NotificationSvc.GetNotificationsAsync();
        isLoading = false;
    }
}
